---
// 版本日志
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

const all = await getCollection('changelog');
const sorted = all.sort((a, b) => b.data.releaseDate.getTime() - a.data.releaseDate.getTime());

// 渲染所有内容
const rendered = await Promise.all(
  sorted.map(async (entry) => ({
    entry,
    Content: (await render(entry)).Content,
  }))
);
---

<BaseLayout title="版本日志" description="Subnautica 2 抢先体验阶段版本变更记录">
  <div class="max-w-3xl mx-auto px-4 py-8">
    <h1 class="font-display text-3xl text-cyan-glow mb-2">版本日志</h1>
    <p class="text-cyan-200/70 mb-6">游戏更新与攻略站内容变更追踪</p>

    <div class="space-y-6">
      {rendered.map(({ entry, Content }) => (
        <article class="bg-deep-800 border border-deep-600 rounded-lg p-5">
          <div class="flex items-center gap-3 mb-2">
            <span class="font-mono text-sm bg-cyan-glow/20 text-cyan-glow px-2 py-1 rounded">
              {entry.data.version}
            </span>
            <time class="text-sm text-cyan-200/60">
              {entry.data.releaseDate.toISOString().slice(0, 10)}
            </time>
          </div>
          <h2 class="font-display text-xl text-cyan-glow mb-2">{entry.data.title}</h2>
          <p class="text-cyan-200/80 mb-3">{entry.data.summary}</p>
          <div class="prose prose-invert prose-sm max-w-none">
            <Content />
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
