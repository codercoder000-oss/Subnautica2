---
// 主线流程列表：按章节分组
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/utils/base';
import Card from '@/components/Card.astro';

const guides = await getCollection('guides');
const sorted = guides.sort((a, b) => a.data.order - b.data.order);

const byChapter = sorted.reduce<Record<string, typeof sorted>>((acc, g) => {
  (acc[g.data.chapter] ??= []).push(g);
  return acc;
}, {});
---

<BaseLayout
  title="主线流程"
  description="深海迷航 2 主线流程指引：节点式攻略，剧透分级，可标记完成进度"
>
  <div class="max-w-5xl mx-auto px-4 py-6">
    <h1 class="font-display text-3xl text-cyan-glow mb-2">主线流程</h1>
    <p class="text-cyan-200/70 mb-6">
      节点式流程指引。每个节点默认隐藏剧情细节，按需展开。完成进度保存在你的浏览器。
    </p>

    {Object.entries(byChapter).map(([chapter, list]) => (
      <section class="mb-8">
        <h2 class="font-display text-xl text-cyan-glow mb-3">{chapter}</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {list.map((g) => (
            <Card
              href={withBase(`/guides/${g.id}/`)}
              title={g.data.title}
              subtitle={g.data.description}
              badge={g.data.estimatedTime}
              badgeColor="bg-cyan-glow/20 text-cyan-glow"
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>


