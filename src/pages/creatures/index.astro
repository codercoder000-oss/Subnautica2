---
// 生物图鉴列表页：适配二代 schema（role + size 三档）
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Card from '@/components/Card.astro';
import { AGGRESSION } from '@/consts';

const all = await getCollection('creatures');

// 按生态分类分组
const ROLE_LABELS: Record<string, string> = {
  leviathan: '利维坦级',
  predator: '掠食者',
  carnivore: '肉食动物',
  herbivore: '食草动物',
  passive: '温和',
  other: '其他',
};

// 排序：利维坦 > 掠食者 > 肉食 > 食草 > 温和 > 其他
const roleOrder = ['leviathan', 'predator', 'carnivore', 'herbivore', 'passive', 'other'];
const sorted = [...all].sort((a, b) => {
  const ra = roleOrder.indexOf(a.data.role);
  const rb = roleOrder.indexOf(b.data.role);
  if (ra !== rb) return ra - rb;
  return a.data.depthMin - b.data.depthMin;
});

// 按 role 分组
const byRole = sorted.reduce<Record<string, typeof sorted>>((acc, c) => {
  (acc[c.data.role] ??= []).push(c);
  return acc;
}, {});
---

<BaseLayout
  title="生物图鉴"
  description="深海迷航 2 全生物图鉴：生态分类、出没深度、攻击性、恐惧症友好标签"
>
  <div class="max-w-7xl mx-auto px-4 py-6">
    <h1 class="font-display text-3xl text-cyan-glow mb-2">生物图鉴</h1>
    <p class="text-cyan-200/70 mb-6">
      共 {all.length} 种生物。按生态分类分组，每个条目标注攻击性和恐惧症友好提示。
    </p>

    <!-- 攻击性图例 -->
    <details class="mb-6 bg-deep-800 border border-deep-600 rounded-lg p-4">
      <summary class="cursor-pointer text-cyan-glow font-semibold">攻击性图例</summary>
      <ul class="mt-3 grid sm:grid-cols-2 gap-2 text-sm">
        {Object.entries(AGGRESSION).map(([key, cfg]) => (
          <li class={cfg.color}>
            <strong>{cfg.label}</strong>：{cfg.desc}
          </li>
        ))}
      </ul>
    </details>

    {roleOrder.map((role) => {
      const list = byRole[role];
      if (!list || list.length === 0) return null;
      return (
        <section class="mb-8">
          <h2 class="font-display text-xl text-cyan-glow mb-3">
            {ROLE_LABELS[role]} <span class="text-sm text-cyan-200/50">({list.length})</span>
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {list.map((c) => {
              const cfg = AGGRESSION[c.data.aggression];
              return (
                <Card
                  href={`/creatures/${c.id}/`}
                  title={c.data.name}
                  subtitle={`${c.data.nameEn} ・ ${c.data.depthMin}~${c.data.depthMax}m`}
                  badge={cfg.label}
                  badgeColor={`bg-deep-700 ${cfg.color}`}
                  image={c.data.image}
                />
              );
            })}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
