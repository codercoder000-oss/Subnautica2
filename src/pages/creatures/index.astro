---
// 生物图鉴列表页：支持过滤和恐惧症标签
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Card from '@/components/Card.astro';
import { AGGRESSION } from '@/consts';

const all = await getCollection('creatures');
// 按攻击性排序：被动 → 致命
const order = { passive: 0, cautious: 1, aggressive: 2, lethal: 3 };
const creatures = all.sort((a, b) =>
  order[a.data.aggression] - order[b.data.aggression]
  || a.data.depthMin - b.data.depthMin
);
---

<BaseLayout
  title="生物图鉴"
  description="深海迷航 2 全生物图鉴：出没深度、攻击性、扫描产物、恐惧症友好标签"
>
  <div class="max-w-7xl mx-auto px-4 py-6">
    <h1 class="font-display text-3xl text-cyan-glow mb-2">生物图鉴</h1>
    <p class="text-cyan-200/70 mb-6">
      共 {creatures.length} 种生物。每个条目标注攻击性、出没深度和恐惧症友好提示。
    </p>

    <!-- 过滤说明 -->
    <details class="mb-6 bg-deep-800 border border-deep-600 rounded-lg p-4">
      <summary class="cursor-pointer text-cyan-glow font-semibold">攻击性图例</summary>
      <ul class="mt-3 grid sm:grid-cols-2 gap-2 text-sm">
        {Object.entries(AGGRESSION).map(([key, cfg]) => (
          <li class={cfg.color}>
            <strong>{cfg.label}</strong>：{cfg.desc}
          </li>
        ))}
      </ul>
    </details>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {creatures.map((c) => {
        const cfg = AGGRESSION[c.data.aggression];
        return (
          <Card
            href={`/creatures/${c.id}/`}
            title={c.data.name}
            subtitle={`${c.data.nameEn} ・ ${c.data.depthMin}~${c.data.depthMax}m`}
            badge={cfg.label}
            badgeColor={`bg-deep-700 ${cfg.color}`}
            image={c.data.image}
          />
        );
      })}
    </div>
  </div>
</BaseLayout>
