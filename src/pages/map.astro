---
// 互动地图页 - wikily.gg 级别效果
import BaseLayout from '@/layouts/BaseLayout.astro';
import GameMap from '@/components/GameMap.tsx';
import { regions, pois } from '@/data/regions';
import { withBase } from '@/utils/base';
---

<BaseLayout
  title="互动地图"
  description="Subnautica 2 互动地图：12 个区域、资源点、黑匣子、危险生物标记，支持分类过滤"
>
  <div class="max-w-[1400px] mx-auto px-4 py-6">
    <!-- 页头 -->
    <div class="mb-4">
      <h1 class="font-display text-2xl text-cyan-glow">互动地图</h1>
      <p class="text-sm text-cyan-200/60">
        Subnautica 2 没有内置地图。这是社区制作的导航工具。
        {regions.length} 个区域 · {pois.length} 个标记点 · 深度 0~596m
      </p>
    </div>

    <!-- ⚠️ EA 数据状态提示 -->
    <div class="mb-4 p-3 bg-yellow-900/20 border border-yellow-700/50 rounded-lg flex items-start gap-2 text-sm">
      <span class="text-lg leading-none">⚠️</span>
      <div class="text-yellow-200/80">
        <strong class="text-yellow-300">EA 数据预览版</strong>：地图瓦片为占位 SVG，标记点基于社区早期数据矿工。
        真实坐标会随每次游戏更新校准，建议结合<a href={withBase('/guides/')} class="text-cyan-glow hover:underline">攻略</a>使用。
      </div>
    </div>

    <!-- 地图 -->
    <GameMap regions={regions} pois={pois} client:only="react" />

    <!-- 底部 SEO 内容 -->
    <section class="mt-10 prose prose-invert prose-cyan max-w-none">
      <h2>Subnautica 2 没有内置地图</h2>
      <p>
        Unknown Worlds 在官方 Discord 确认，Subnautica 2 不会自带内置地图。
        和原版 Subnautica 以及 Below Zero 一样，工作室希望玩家通过观察环境、
        学习地标和使用指南针来导航。PDA、指南针和信标是游戏内的导航工具。
      </p>

      <h2>如何在没有地图的情况下导航</h2>
      <ol>
        <li><strong>指南针优先</strong>：屏幕上的指南针显示方向，是每次导航决策的基础</li>
        <li><strong>用地标不用坐标</strong>：记住每个区域 3-5 个地标（尖塔、残骸轮廓、特殊植物）</li>
        <li><strong>深潜前放信标</strong>：Beacon 可穿透地形，从远处可见</li>
        <li><strong>扫描一切</strong>：PDA 扫描会记录生物群落笔记，是你的「软地图」</li>
        <li><strong>用本页地图看布局</strong>：规划路线，避开利维坦区域</li>
      </ol>

      <h2>区域结构</h2>
      <p>
        Subnautica 2 在生态区系统上增加了「区域」层级。一个区域包含多个主题生态区和子生态区。
        EA 阶段至少有 2 个大区域，后续更新会加入更多。地图半径约 2 公里，最大深度 596 米。
      </p>

      <h2>常见问题</h2>
      <details>
        <summary>Subnautica 2 有内置地图吗？</summary>
        <p>没有。Unknown Worlds 确认不会加入内置地图，和一代设计一致。</p>
      </details>
      <details>
        <summary>地图有多大？</summary>
        <p>半径约 2 公里，16 个区域，最大深度 596 米。</p>
      </details>
      <details>
        <summary>怎么看坐标？</summary>
        <p>按 F1 打开调试信息，可以看到当前 X/Y/Z 坐标。</p>
      </details>
    </section>
  </div>
</BaseLayout>
