---
// 搜索页：Pagefind 全文搜索
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="搜索" description="搜索深海迷航 2 全站内容">
  <div class="max-w-3xl mx-auto px-4 py-8">
    <h1 class="font-display text-2xl text-cyan-glow mb-6">搜索</h1>
    <div id="search"></div>
  </div>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <style>
    /* 覆盖 Pagefind UI 样式适配深色主题 */
    :root {
      --pagefind-ui-scale: 0.9;
      --pagefind-ui-primary: #4dd0e1;
      --pagefind-ui-text: #e0f7fa;
      --pagefind-ui-background: #0a1628;
      --pagefind-ui-border: #18324f;
      --pagefind-ui-tag: #102339;
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 8px;
      --pagefind-ui-font: 'Inter', system-ui, sans-serif;
    }
    .pagefind-ui__search-input {
      background: #102339 !important;
      color: #e0f7fa !important;
      border-color: #18324f !important;
    }
    .pagefind-ui__search-input:focus {
      border-color: #4dd0e1 !important;
      box-shadow: 0 0 0 2px rgba(77, 208, 225, 0.2) !important;
    }
    .pagefind-ui__result-link {
      color: #4dd0e1 !important;
    }
    .pagefind-ui__result-link:hover {
      color: #80deea !important;
    }
    .pagefind-ui__result-excerpt {
      color: #b2dfdb !important;
    }
    .pagefind-ui__message {
      color: #80cbc4 !important;
    }
    .pagefind-ui__button {
      background: #102339 !important;
      color: #4dd0e1 !important;
      border-color: #18324f !important;
    }
    .pagefind-ui__button:hover {
      background: #18324f !important;
    }
  </style>

  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function() {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        translations: {
          placeholder: '搜索生物、物品、攻略...',
          clear_search: '清除',
          load_more: '加载更多',
          search_label: '搜索',
          filters_label: '筛选',
          zero_results: '没有找到相关内容',
          many_results: '找到 [COUNT] 条结果',
          one_result: '找到 1 条结果',
          searching: '搜索中...',
        },
      });
    });
  </script>
</BaseLayout>
