---
// 物品 / 蓝图列表页
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/utils/base';
import Card from '@/components/Card.astro';

const items = await getCollection('items');

// 按类别分组
const byCategory = items.reduce<Record<string, typeof items>>((acc, item) => {
  const c = item.data.category;
  (acc[c] ??= []).push(item);
  return acc;
}, {});

const CATEGORY_LABELS: Record<string, string> = {
  raw: '基础材料',
  basic: '基础合成物',
  advanced: '高级合成物',
  equipment: '装备',
  vehicle: '载具',
  base: '基地模块',
  tool: '工具',
  food: '食物',
};
---

<BaseLayout
  title="物品蓝图"
  description="深海迷航 2 全物品蓝图：配方、获取地点、合成器分类"
>
  <div class="max-w-7xl mx-auto px-4 py-6">
    <h1 class="font-display text-3xl text-cyan-glow mb-2">物品蓝图</h1>
    <p class="text-cyan-200/70 mb-6">共 {items.length} 个条目，按类别分组</p>

    {Object.entries(byCategory).map(([cat, list]) => (
      <section class="mb-8">
        <h2 class="font-display text-xl text-cyan-glow mb-3">
          {CATEGORY_LABELS[cat] ?? cat} <span class="text-sm text-cyan-200/50">({list.length})</span>
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          {list.map((item) => (
            <Card
              href={withBase(`/items/${item.id}/`)}
              title={item.data.name}
              subtitle={item.data.nameEn}
              image={item.data.image}
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>


