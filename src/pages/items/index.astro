---
// 物品 / 蓝图列表页：Tab 过滤 + 顶部统计 + SEO 长文 + FAQ
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/utils/base';

const all = await getCollection('items');

const CATEGORY_LABELS: Record<string, { label: string; desc: string }> = {
  raw: { label: '基础材料', desc: '矿石、植物等可直接采集的原料' },
  basic: { label: '基础合成物', desc: '前期 Fabricator 一步合成的物品' },
  advanced: { label: '高级合成物', desc: '依赖稀有材料、需多步合成' },
  tool: { label: '工具', desc: '扫描枪、Sonic Resonator 等手持设备' },
  equipment: { label: '装备', desc: '氧气瓶、护甲、电池等穿戴件' },
  food: { label: '食物', desc: '熟食、水瓶等消耗品' },
  base: { label: '基地模块', desc: '走廊、仓房、设施等建造件' },
  vehicle: { label: '载具', desc: 'Tadpole 及其变体' },
};

const categoryOrder = ['raw', 'basic', 'tool', 'equipment', 'food', 'advanced', 'base', 'vehicle'];

const byCategory = all.reduce<Record<string, typeof all>>((acc, it) => {
  (acc[it.data.category] ??= []).push(it);
  return acc;
}, {});

// FAQ
const faqItems = [
  {
    q: 'Subnautica 2 怎么获取蓝图？',
    a: '主要通过扫描碎片：使用 Scanner Tool 对准残骸或外星装置碎片，扫描完整数量后蓝图自动加入 Fabricator 配方列表。少量蓝图通过剧情或 Biolab 研究解锁。',
  },
  {
    q: '为什么我合成不了某个物品？',
    a: '检查三件事：1) 蓝图是否解锁（碎片扫够），2) 材料是否在制造机或角色背包内，3) 是否在正确的合成器（Fabricator / Habitat Builder / Modification Station）。',
  },
  {
    q: 'Raw Ore 是什么？',
    a: '二代特有机制：海底找到的灰色矿石节点，扔进 Fabricator 随机分解为钛 / 铜 / 石英。一代的独立矿种被这种统一系统替代。',
  },
  {
    q: '哪些工具是前期必造的？',
    a: 'Survival Multi-Tool（钛 ×3）→ Scanner Tool（扫描蓝图）→ Habitat Builder（建造基地）→ Air Tank（延长氧气）。Sonic Resonator 是中期最重要的工具。',
  },
];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const CRAFTER_LABELS: Record<string, string> = {
  fabricator: '制造机',
  'mobile-fabricator': '移动制造器',
  'modification-station': '改造台',
  'vehicle-bay': '载具维修舱',
  'habitat-builder': '栖息地建造工具',
  none: '无需合成',
};
---

<BaseLayout
  title="物品蓝图"
  description="深海迷航 2 全物品蓝图：配方、合成器、获取地点、按类别筛选"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-7xl mx-auto px-4 py-6">
    <!-- 页头 -->
    <div class="mb-6">
      <h1 class="font-display text-3xl text-cyan-glow mb-2">物品蓝图</h1>
      <p class="text-cyan-200/70">
        共 <strong class="text-cyan-glow">{all.length}</strong> 个条目，按类别筛选，含合成器和配方信息。
      </p>
    </div>

    <!-- 搜索 + Tab 过滤器 -->
    <div class="sticky top-[88px] z-30 bg-deep-900/95 backdrop-blur py-3 -mx-4 px-4 mb-6 border-b border-deep-600 space-y-3">
      <input
        id="item-filter-input"
        type="search"
        placeholder="按中文名 / 英文名筛选..."
        class="w-full px-4 py-2 bg-deep-700 border border-deep-600 rounded-lg text-cyan-50 placeholder-cyan-200/40 focus:outline-none focus:border-cyan-glow transition"
        autocomplete="off"
      />
      <div class="flex flex-wrap gap-2">
        <button data-cat-filter="all" class="cat-filter-btn px-4 py-2 rounded-full bg-cyan-glow text-deep-900 text-sm font-semibold cursor-pointer">
          全部 {all.length}
        </button>
        {categoryOrder.map((cat) => {
          const list = byCategory[cat];
          if (!list || list.length === 0) return null;
          const cfg = CATEGORY_LABELS[cat];
          return (
            <button
              data-cat-filter={cat}
              class="cat-filter-btn px-4 py-2 rounded-full bg-deep-700 hover:bg-deep-600 text-sm transition cursor-pointer"
            >
              {cfg?.label ?? cat} {list.length}
            </button>
          );
        })}
      </div>
    </div>

    <!-- 分类列表 -->
    {categoryOrder.map((cat) => {
      const list = byCategory[cat];
      if (!list || list.length === 0) return null;
      const cfg = CATEGORY_LABELS[cat];
      return (
        <section id={cat} data-cat-section={cat} class="mb-10 scroll-mt-32">
          <div class="mb-4">
            <h2 class="font-display text-xl text-cyan-glow">{cfg?.label ?? cat}</h2>
            {cfg?.desc && <p class="text-sm text-cyan-200/60">{cfg.desc}</p>}
            <span class="text-xs text-cyan-200/40">{list.length} 个</span>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3">
            {list.map((it) => (
              <a
                href={withBase(`/items/${it.id}/`)}
                data-item-card
                data-name={`${it.data.name.toLowerCase()} ${it.data.nameEn.toLowerCase()}`}
                class="group block bg-deep-800 border border-deep-600 rounded-lg overflow-hidden hover:border-cyan-glow hover:shadow-lg hover:shadow-cyan-glow/10 transition"
              >
                {it.data.image ? (
                  <div class="aspect-square bg-deep-900 overflow-hidden">
                    <img
                      src={it.data.image}
                      alt={it.data.name}
                      loading="lazy"
                      class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
                    />
                  </div>
                ) : (
                  <div class="aspect-square bg-deep-900 flex items-center justify-center text-3xl opacity-30">
                    🔧
                  </div>
                )}
                <div class="p-3">
                  <h3 class="font-semibold text-sm text-cyan-glow group-hover:text-cyan-300 truncate">
                    {it.data.name}
                  </h3>
                  <p class="text-xs text-cyan-200/50 truncate">{it.data.nameEn}</p>
                  <div class="flex items-center gap-2 mt-2">
                    <span class="text-xs px-1.5 py-0.5 rounded bg-deep-700 text-cyan-200/70">
                      {CRAFTER_LABELS[it.data.crafter]}
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    <!-- SEO 长文 -->
    <section class="mt-12 pt-8 border-t border-deep-600 prose prose-invert prose-cyan max-w-none">
      <h2 class="font-display text-cyan-glow">关于 Subnautica 2 物品系统</h2>
      <p>
        Subnautica 2 的物品系统在一代基础上做了深度改造。最显著的变化是
        <strong>Raw Ore 节点机制</strong>：海底不再有独立铜矿、石英矿，
        所有矿石节点统一为灰色 Raw Ore，捡回基地放进 Fabricator 随机分解为钛 / 铜 / 石英。
        这降低了识别成本但提高了批量采集的重要性。
      </p>

      <h3>四类合成器</h3>
      <ul>
        <li><strong>Fabricator（制造机）</strong>：基础合成器，分解 Raw Ore、合成基础物品</li>
        <li><strong>Habitat Builder（栖息地建造工具）</strong>：建造基地外壳和模块</li>
        <li><strong>Modification Station（改造台）</strong>：升级装备和载具</li>
        <li><strong>Vehicle Bay（载具维修舱）</strong>：组装 Tadpole 和变体</li>
      </ul>

      <h3>蓝图获取</h3>
      <p>
        大部分蓝图通过<strong>扫描碎片</strong>解锁。每件设备需要扫描 1-3 个碎片才能完整获得配方。
        碎片散落在 CICADA 残骸、Old Habitat、Wandering Blackbox 等点位。
        关键工具如 Sonic Resonator、Habitat Builder 都需要扫描碎片解锁。
      </p>

      <h3>资源稀缺度</h3>
      <ul>
        <li><strong>钛 / 铜 / 石英</strong>：通过 Raw Ore 分解和 Metal Salvage 转化获取，相对充足</li>
        <li><strong>银</strong>：只在洞穴内，前期最关键稀缺资源</li>
        <li><strong>金</strong>：深层洞穴，高级电子元件必备</li>
        <li><strong>铅</strong>：深海矿脉和 CICADA 残骸，辐射防护用</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mt-12 pt-8 border-t border-deep-600">
      <h2 class="font-display text-xl text-cyan-glow mb-4">常见问题</h2>
      <div class="space-y-3">
        {faqItems.map((f, i) => (
          <details class="group bg-deep-800 border border-deep-600 rounded-lg overflow-hidden">
            <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer hover:bg-deep-700 transition">
              <span class="shrink-0 w-5 h-5 rounded-full bg-cyan-glow/20 text-cyan-glow flex items-center justify-center text-xs font-bold">
                {i + 1}
              </span>
              <span class="font-semibold text-sm flex-1">{f.q}</span>
              <svg class="w-4 h-4 text-cyan-200/50 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-4 pb-3 pt-1 text-sm text-cyan-200/80 border-t border-deep-600">
              {f.a}
            </div>
          </details>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // 列表过滤：按 category 切换 + 名称模糊搜索（同时生效）
  const input = document.getElementById('item-filter-input') as HTMLInputElement | null;
  const buttons = document.querySelectorAll<HTMLButtonElement>('.cat-filter-btn');
  const sections = document.querySelectorAll<HTMLElement>('[data-cat-section]');

  let activeCat = 'all';
  let keyword = '';

  function apply() {
    const kw = keyword.trim().toLowerCase();
    sections.forEach((sec) => {
      const cat = sec.dataset.catSection!;
      const catMatch = activeCat === 'all' || activeCat === cat;
      if (!catMatch) {
        sec.classList.add('hidden');
        return;
      }
      const inner = sec.querySelectorAll<HTMLAnchorElement>('[data-item-card]');
      let visibleCount = 0;
      inner.forEach((card) => {
        const name = card.dataset.name ?? '';
        const ok = !kw || name.includes(kw);
        card.classList.toggle('hidden', !ok);
        if (ok) visibleCount++;
      });
      sec.classList.toggle('hidden', visibleCount === 0);
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.catFilter!;
      buttons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('bg-cyan-glow', on);
        b.classList.toggle('text-deep-900', on);
        b.classList.toggle('font-semibold', on);
        b.classList.toggle('bg-deep-700', !on);
        b.classList.toggle('hover:bg-deep-600', !on);
      });
      apply();
    });
  });

  input?.addEventListener('input', () => {
    keyword = input.value;
    apply();
  });
</script>
