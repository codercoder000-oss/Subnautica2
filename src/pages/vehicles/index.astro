---
// 载具页
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/utils/base';
import Card from '@/components/Card.astro';
import VersionBadge from '@/components/VersionBadge.astro';

const items = await getCollection('items');
const vehicles = items.filter((i) => i.data.category === 'vehicle');
---

<BaseLayout
  title="载具"
  description="深海迷航 2 全载具：解锁路径、配方、升级模块、操作技巧"
>
  <div class="max-w-5xl mx-auto px-4 py-6">
    <div class="mb-4 flex items-baseline justify-between flex-wrap gap-2">
      <h1 class="font-display text-3xl text-cyan-glow">载具</h1>
      <VersionBadge />
    </div>

    <p class="text-cyan-200/70 mb-6">
      载具是深海探索的核心。每种载具有不同的深度极限和功能定位。
    </p>

    {vehicles.length > 0 ? (
      <div class="grid sm:grid-cols-2 gap-4">
        {vehicles.map((v) => (
          <Card
            href={withBase(`/items/${v.id}/`)}
            title={v.data.name}
            subtitle={v.data.nameEn}
            image={v.data.image}
            badge="载具"
            badgeColor="bg-orange-900/50 text-orange-300"
          />
        ))}
      </div>
    ) : (
      <div class="bg-deep-800 border border-deep-600 rounded-lg p-8 text-center">
        <p class="text-cyan-200/70">
          载具数据收集中。Subnautica 2 的载具系统与一代有较大变化，
          待抢先体验阶段确认后补充。
        </p>
      </div>
    )}

    <!-- 载具对比表（占位） -->
    <section class="mt-8 bg-deep-800 border border-deep-600 rounded-lg p-6">
      <h2 class="font-display text-xl text-cyan-glow mb-3">载具对比</h2>
      <p class="text-cyan-200/60 text-sm mb-4">
        二代载具系统正在抢先体验阶段迭代中，以下为已知信息：
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-left text-cyan-200/70 border-b border-deep-600">
            <tr>
              <th class="py-2">载具</th>
              <th class="py-2">默认深度</th>
              <th class="py-2">定位</th>
              <th class="py-2">特点</th>
            </tr>
          </thead>
          <tbody class="text-cyan-200/80">
            <tr class="border-b border-deep-700">
              <td class="py-2">海蛾号</td>
              <td class="py-2 font-mono">200m</td>
              <td class="py-2">侦察</td>
              <td class="py-2">机动性强、加速快</td>
            </tr>
            <tr class="border-b border-deep-700">
              <td class="py-2">旋风者</td>
              <td class="py-2 font-mono">500m</td>
              <td class="py-2">移动基地</td>
              <td class="py-2">可搭载海蛾号、内部可建造</td>
            </tr>
            <tr class="border-b border-deep-700">
              <td class="py-2">阿瓦塔号</td>
              <td class="py-2 font-mono">900m</td>
              <td class="py-2">深海采矿</td>
              <td class="py-2">近战强、钻头采矿、耐压</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-cyan-200/50 mt-3">
        ⚠️ 二代可能有新载具或改动，以游戏实际为准。
      </p>
    </section>
  </div>
</BaseLayout>

