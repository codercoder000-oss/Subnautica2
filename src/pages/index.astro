---
// 首页：决策型内容 + 入口聚合
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Card from '@/components/Card.astro';
import { SITE } from '@/consts';

// 获取最新版本日志
const changelog = await getCollection('changelog');
const latestChange = changelog.sort(
  (a, b) => b.data.releaseDate.getTime() - a.data.releaseDate.getTime()
)[0];

// 获取主线流程第一章
const guides = await getCollection('guides');
const firstGuides = guides
  .filter((g) => !g.data.outdated)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

// 危险生物预览
const creatures = await getCollection('creatures');
const dangerCreatures = creatures
  .filter((c) => c.data.aggression === 'lethal' || c.data.aggression === 'aggressive')
  .slice(0, 4);
---

<BaseLayout>
  <!-- Hero 区 -->
  <section class="relative bg-gradient-to-b from-deep-900 via-deep-800 to-deep-900 border-b border-deep-600">
    <div class="max-w-7xl mx-auto px-4 py-16 md:py-24">
      <div class="max-w-3xl">
        <h1 class="font-display text-4xl md:text-6xl font-bold text-cyan-glow mb-4">
          Subnautica 2 攻略站
        </h1>
        <p class="text-lg md:text-xl text-cyan-100/80 mb-8">
          深海迷航 2 中文社区攻略：互动地图、生物图鉴、配方计算器、主线流程指引。
          每条内容都标注适用版本，告别过时攻略。
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/guides/"
            class="px-6 py-3 bg-cyan-glow text-deep-900 rounded-lg font-semibold hover:bg-cyan-300 transition"
          >
            从主线流程开始 →
          </a>
          <a
            href="/map/"
            class="px-6 py-3 bg-deep-600 hover:bg-deep-700 rounded-lg font-semibold transition"
          >
            打开互动地图
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 py-12 space-y-12">
    <!-- 今天该做什么（决策型） -->
    <section>
      <div class="flex items-baseline justify-between mb-4">
        <h2 class="font-display text-2xl text-cyan-glow">今天该做什么</h2>
        <a href="/guides/" class="text-sm hover:text-cyan-glow">查看全部 →</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {firstGuides.map((g) => (
          <Card
            href={`/guides/${g.id}/`}
            title={g.data.title}
            subtitle={g.data.description}
            badge={g.data.estimatedTime}
            badgeColor="bg-cyan-glow/20 text-cyan-glow"
          />
        ))}
      </div>
    </section>

    <!-- 版本动态 -->
    {latestChange && (
      <section class="bg-deep-800 border border-deep-600 rounded-lg p-6">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="font-display text-xl text-cyan-glow">最新版本变化</h2>
          <a href="/changelog/" class="text-sm hover:text-cyan-glow">完整日志 →</a>
        </div>
        <div class="flex items-center gap-3 mb-2">
          <span class="font-mono text-sm bg-cyan-glow/20 text-cyan-glow px-2 py-1 rounded">
            {latestChange.data.version}
          </span>
          <span class="text-sm text-cyan-200/60">
            {latestChange.data.releaseDate.toISOString().slice(0, 10)}
          </span>
        </div>
        <h3 class="text-lg font-semibold mb-1">{latestChange.data.title}</h3>
        <p class="text-cyan-200/80">{latestChange.data.summary}</p>
      </section>
    )}

    <!-- 危险生物提醒 -->
    <section>
      <div class="flex items-baseline justify-between mb-4">
        <h2 class="font-display text-2xl text-cyan-glow">深海威胁</h2>
        <a href="/creatures/" class="text-sm hover:text-cyan-glow">完整图鉴 →</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {dangerCreatures.map((c) => (
          <Card
            href={`/creatures/${c.id}/`}
            title={c.data.name}
            subtitle={`深度 ${c.data.depthMin}m ~ ${c.data.depthMax}m`}
            badge={c.data.aggression === 'lethal' ? '致命' : '主动攻击'}
            badgeColor={c.data.aggression === 'lethal' ? 'bg-red-900/50 text-red-300' : 'bg-orange-900/50 text-orange-300'}
            image={c.data.image}
          />
        ))}
      </div>
    </section>

    <!-- 工具入口 -->
    <section>
      <h2 class="font-display text-2xl text-cyan-glow mb-4">实用工具</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <Card
          href="/map/"
          title="互动地图"
          subtitle="多层切换、标记过滤、自定义标记、剧透分级"
          badge="核心工具"
          badgeColor="bg-cyan-glow/20 text-cyan-glow"
        />
        <Card
          href="/tools/calculator/"
          title="配方计算器"
          subtitle="输入目标物品，自动计算所需基础材料清单"
          badge="必备"
          badgeColor="bg-cyan-glow/20 text-cyan-glow"
        />
        <Card
          href="/tools/tech-tree/"
          title="科技树可视化"
          subtitle="蓝图依赖关系图，规划解锁路径"
        />
      </div>
    </section>
  </div>
</BaseLayout>
