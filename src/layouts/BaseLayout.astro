---
// 全站基础布局
import { SITE, NAV } from '@/consts';
import MobileNav from '@/components/MobileNav.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage = '/og-default.png',
  noIndex = false,
} = Astro.props;

const fullTitle = title ? `${title} | ${SITE.title}` : SITE.title;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {noIndex && <meta name="robots" content="noindex" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content={SITE.title} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- 字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-deep-900 text-cyan-50 min-h-screen flex flex-col">
    <!-- 顶部导航 -->
    <header class="sticky top-0 z-50 bg-deep-800/95 backdrop-blur-md border-b border-deep-600/50">
      <div class="max-w-7xl mx-auto px-4 py-2.5 flex items-center gap-4">
        <a href="/" class="font-display font-bold text-cyan-glow text-base whitespace-nowrap hover:opacity-80 transition">
          🌊 {SITE.title}
        </a>
        <nav class="flex-1 overflow-x-auto hidden lg:block scrollbar-hide">
          <ul class="flex items-center gap-0.5 text-[13px]">
            {NAV.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="px-2.5 py-1.5 rounded-md hover:bg-deep-600/70 hover:text-cyan-glow transition whitespace-nowrap inline-block text-cyan-100/80"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <a
          href="/search/"
          class="hidden lg:inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-lg bg-deep-700 border border-deep-600 hover:border-cyan-glow hover:text-cyan-glow transition"
          aria-label="搜索"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          搜索
        </a>
        <MobileNav />
      </div>
      <!-- 版本提示条 -->
      <div class="bg-deep-700/50 border-t border-deep-600/30 text-[11px] text-cyan-200/50 text-center py-0.5">
        游戏版本 <span class="text-cyan-glow/80 font-mono">{SITE.gameVersion}</span>
        <span class="mx-1.5 text-deep-600">|</span>
        {SITE.gameVersionDate}
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- 页脚 -->
    <footer class="border-t border-deep-600 bg-deep-800 mt-12">
      <div class="max-w-7xl mx-auto px-4 py-8 text-sm text-cyan-200/60 space-y-4">
        <div class="grid md:grid-cols-3 gap-6">
          <div>
            <h3 class="font-display text-cyan-glow mb-2">{SITE.title}</h3>
            <p>{SITE.description}</p>
          </div>
          <div>
            <h3 class="font-display text-cyan-glow mb-2">导航</h3>
            <ul class="space-y-1">
              {NAV.slice(0, 6).map((item) => (
                <li><a href={item.href} class="hover:text-cyan-glow">{item.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="font-display text-cyan-glow mb-2">关于</h3>
            <ul class="space-y-1">
              <li><a href="/about/" class="hover:text-cyan-glow">站点说明</a></li>
              <li><a href="/contribute/" class="hover:text-cyan-glow">贡献指南</a></li>
              <li><a href="https://github.com/" class="hover:text-cyan-glow">GitHub 仓库</a></li>
            </ul>
          </div>
        </div>
        <!-- Fan-made 声明 -->
        <div class="pt-4 border-t border-deep-600 text-xs text-cyan-200/50">
          <p>{SITE.disclaimer}</p>
          <p class="mt-1">© {new Date().getFullYear()} {SITE.author}. 内容采用 CC BY-NC-SA 4.0 协议。</p>
        </div>
      </div>
    </footer>
  </body>
</html>
