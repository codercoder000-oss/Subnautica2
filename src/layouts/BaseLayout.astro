---
// 全站基础布局
import { SITE, NAV } from '@/consts';
import MobileNav from '@/components/MobileNav.astro';
import SearchModal from '@/components/SearchModal.astro';
import LangSwitch from '@/components/LangSwitch.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage = '/og-default.svg',
  noIndex = false,
} = Astro.props;

// base URL（处理 GitHub Pages 子路径）
const base = import.meta.env.BASE_URL;
// 给路径加 base 前缀的工具函数
const withBase = (path: string) => `${base}${path.startsWith('/') ? path.slice(1) : path}`;

const fullTitle = title ? `${title} | ${SITE.title}` : SITE.title;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

// 站点级 WebSite + SearchAction schema：让搜索引擎知道有站内搜索
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.title,
  url: Astro.site?.toString(),
  description: SITE.description,
  inLanguage: 'zh-CN',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${Astro.site?.toString().replace(/\/$/, '')}${withBase('/')}?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {noIndex && <meta name="robots" content="noindex" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content={SITE.title} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- 字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- 站点 WebSite schema（含 SearchAction） -->
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1397686696757932" crossorigin="anonymous"></script>
  </head>
  <body class="bg-deep-900 text-cyan-50 min-h-screen flex flex-col">
    <!-- 阅读进度条 -->
    <div id="reading-progress" class="fixed top-0 left-0 right-0 h-0.5 bg-cyan-glow z-[60] origin-left scale-x-0 transition-transform duration-100" style="transform-origin: left;"></div>

    <!-- 顶部导航 -->
    <header class="sticky top-0 z-50 bg-deep-800/95 backdrop-blur-md border-b border-deep-600/50">
      <div class="max-w-7xl mx-auto px-4 py-2.5 flex items-center gap-4">
        <a href={withBase('/')} class="font-display font-bold text-cyan-glow text-base whitespace-nowrap hover:opacity-80 transition">
          🌊 {SITE.title}
        </a>
        <nav class="flex-1 overflow-x-auto hidden lg:block scrollbar-hide">
          <ul class="flex items-center gap-0.5 text-[13px]">
            {NAV.map((item) => (
              <li>
                <a
                  href={withBase(item.href)}
                  class="px-2.5 py-1.5 rounded-md hover:bg-deep-600/70 hover:text-cyan-glow transition whitespace-nowrap inline-block text-cyan-100/80"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <button
          data-open-search
          class="hidden lg:inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-lg bg-deep-700 border border-deep-600 hover:border-cyan-glow hover:text-cyan-glow transition cursor-pointer"
          aria-label="搜索"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          搜索
          <kbd class="text-[10px] text-cyan-200/30 ml-1">Ctrl+K</kbd>
        </button>
        <LangSwitch />
        <MobileNav />
      </div>
      <!-- 版本提示条 -->
      <div class="bg-deep-700/50 border-t border-deep-600/30 text-[11px] text-cyan-200/50 text-center py-0.5">
        游戏版本 <span class="text-cyan-glow/80 font-mono">{SITE.gameVersion}</span>
        <span class="mx-1.5 text-deep-600">|</span>
        {SITE.gameVersionDate}
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- 简化页脚 -->
    <footer class="border-t border-deep-600/50 bg-deep-800/50 mt-12">
      <div class="max-w-7xl mx-auto px-4 py-6 text-xs text-cyan-200/50">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
          <div class="flex items-center gap-4">
            <span class="font-display text-cyan-glow/70">{SITE.title}</span>
            <a href={withBase('/about/')} class="hover:text-cyan-glow">关于</a>
            <a href={withBase('/privacy/')} class="hover:text-cyan-glow">Privacy Policy</a>
            <a href={withBase('/contribute/')} class="hover:text-cyan-glow">贡献</a>
          </div>
          <p>{SITE.disclaimer}</p>
        </div>
        <p class="text-center mt-3 text-cyan-200/30">
          © {new Date().getFullYear()} {SITE.author} · CC BY-NC-SA 4.0
        </p>
      </div>
    </footer>

    <!-- 搜索弹窗 -->
    <SearchModal />

    <!-- 返回顶部按钮 -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full bg-deep-700 border border-deep-600 text-cyan-glow flex items-center justify-center opacity-0 pointer-events-none transition-all hover:bg-cyan-glow hover:text-deep-900 hover:scale-110"
      aria-label="返回顶部"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <script>
      const btn = document.getElementById('back-to-top');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) {
          btn?.classList.remove('opacity-0', 'pointer-events-none');
          btn?.classList.add('opacity-100');
        } else {
          btn?.classList.add('opacity-0', 'pointer-events-none');
          btn?.classList.remove('opacity-100');
        }
      });
      btn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // 阅读进度条：scroll 高度 / 文档总高度
      const bar = document.getElementById('reading-progress');
      function updateProgress() {
        const h = document.documentElement;
        const max = h.scrollHeight - h.clientHeight;
        const ratio = max > 0 ? Math.min(1, h.scrollTop / max) : 0;
        if (bar) bar.style.transform = `scaleX(${ratio})`;
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    </script>
  </body>
</html>
