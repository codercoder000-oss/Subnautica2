---
// 相关内容推荐：底部展示相关页面
interface RelatedItem {
  href: string;
  title: string;
  subtitle?: string;
}

interface Props {
  items: RelatedItem[];
  title?: string;
}

const { items, title = '相关内容' } = Astro.props;
---

{items.length > 0 && (
  <section class="mt-8 pt-6 border-t border-deep-600">
    <h2 class="font-display text-cyan-glow text-lg mb-3">{title}</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {items.map((item) => (
        <a
          href={item.href}
          class="block p-3 bg-deep-800 border border-deep-600 rounded-lg hover:border-cyan-glow hover:bg-deep-700 transition"
        >
          <span class="text-cyan-glow font-semibold text-sm">{item.title}</span>
          {item.subtitle && (
            <span class="block text-xs text-cyan-200/60 mt-1">{item.subtitle}</span>
          )}
        </a>
      ))}
    </div>
  </section>
)}
