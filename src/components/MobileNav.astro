---
// 移动端汉堡菜单
import { NAV } from '@/consts';
---

<!-- 汉堡按钮（仅移动端显示） -->
<button
  id="mobile-nav-toggle"
  class="lg:hidden p-2 rounded hover:bg-deep-600 transition"
  aria-label="打开导航菜单"
  aria-expanded="false"
>
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<!-- 移动端侧滑菜单 -->
<div
  id="mobile-nav-overlay"
  class="fixed inset-0 z-[100] hidden"
>
  <!-- 遮罩 -->
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-close-nav></div>
  <!-- 菜单面板 -->
  <nav class="absolute right-0 top-0 bottom-0 w-72 bg-deep-800 border-l border-deep-600 p-6 overflow-y-auto">
    <div class="flex items-center justify-between mb-6">
      <span class="font-display text-cyan-glow text-sm">导航</span>
      <button data-close-nav class="p-2 rounded hover:bg-deep-600" aria-label="关闭菜单">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <ul class="space-y-1">
      {NAV.map((item) => (
        <li>
          <a
            href={item.href}
            class="block px-3 py-2.5 rounded hover:bg-deep-600 hover:text-cyan-glow transition"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="mt-6 pt-4 border-t border-deep-600">
      <a
        href="/search/"
        class="block px-3 py-2.5 rounded bg-deep-700 hover:bg-cyan-glow hover:text-deep-900 transition text-center"
      >
        🔍 搜索
      </a>
    </div>
  </nav>
</div>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const overlay = document.getElementById('mobile-nav-overlay');

  function open() {
    overlay?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    overlay?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', open);
  overlay?.querySelectorAll('[data-close-nav]').forEach((el) => {
    el.addEventListener('click', close);
  });
  // ESC 关闭
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>
