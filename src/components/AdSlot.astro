---
// 广告位组件：文章中间 / 底部插入 AdSense 广告
// 用法：<AdSlot position="mid" /> 或 <AdSlot position="bottom" />
interface Props {
  position?: 'mid' | 'bottom' | 'sidebar';
}

const { position = 'mid' } = Astro.props;

// 不同位置用不同的广告格式
const formats: Record<string, string> = {
  mid: 'fluid',      // 文章中间：自适应流式
  bottom: 'auto',    // 文章底部：自动尺寸
  sidebar: 'vertical', // 侧栏：垂直
};
---

<div class="ad-slot my-8 flex justify-center" data-ad-position={position}>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-1397686696757932"
    data-ad-slot=""
    data-ad-format={formats[position]}
    data-full-width-responsive="true"
  ></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>

<style>
  .ad-slot {
    min-height: 90px;
    background: transparent;
  }
  /* 广告加载前的占位提示（可选，审核通过后可去掉） */
  .ad-slot ins:empty::after {
    content: '';
    display: block;
  }
</style>
